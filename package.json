{
  "name": "@archoleat/eslint-flat-compatibility",
  "description": "Function for compatibility with ESLint flat config",
  "version": "1.1.1",
  "license": "MIT",
  "author": {
    "email": "archoleat@gmail.com",
    "name": "Archoleat",
    "url": "https://github.com/archoleat"
  },
  "homepage": "https://github.com/archoleat/eslint-flat-compatibility#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/archoleat/eslint-flat-compatibility.git"
  },
  "bugs": {
    "url": "https://github.com/archoleat/eslint-flat-compatibility/issues"
  },
  "keywords": [
    "compatibility",
    "config",
    "eslint-config",
    "eslint-flat-compatibility",
    "eslint-flat-config",
    "eslint",
    "flat"
  ],
  "packageManager": "pnpm@8.15.6",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0",
    "pnpm": ">=8.0.0"
  },
  "volta": {
    "node": "20.12.0",
    "pnpm": "8.15.6"
  },
  "type": "module",
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "index.js"
  ],
  "scripts": {
    "init": "pnpm i && husky",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "rollup -c",
    "release": "semantic-release",
    "lint:editorconfig": "editorconfig-checker",
    "lint:formatting": "prettier . --check",
    "lint:md": "remark . --quiet",
    "lint:ts": "eslint src/**/*.ts --fix",
    "prettify": "prettier . --write",
    "commit": "cz"
  },
  "dependencies": {
    "@eslint/eslintrc": "^3.0.2",
    "@types/eslint": "^8.56.7",
    "@types/eslint__eslintrc": "^2.1.1"
  },
  "devDependencies": {
    "@archoleat/commitlint-define-config": "^1.0.2",
    "@archoleat/eslint-flat-compatibility": "file:",
    "@archoleat/semantic-release-define-config": "^1.1.1",
    "@commitlint/cli": "^19.2.1",
    "@commitlint/config-conventional": "^19.1.0",
    "@rollup/plugin-typescript": "^11.1.6",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^7.5.0",
    "@typescript-eslint/parser": "^7.5.0",
    "@vitest/coverage-v8": "^1.4.0",
    "conventional-changelog-conventionalcommits": "^7.0.2",
    "cz-conventional-changelog": "^3.3.0",
    "editorconfig-checker": "^5.1.5",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-define-config": "^2.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-unicorn": "^51.0.1",
    "globals": "^15.0.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "remark": "15.0.1",
    "remark-cli": "^12.0.0",
    "remark-preset-lint-consistent": "^5.1.2",
    "remark-preset-lint-markdown-style-guide": "^5.1.3",
    "remark-preset-lint-recommended": "^6.1.3",
    "rollup": "^4.14.0",
    "rollup-plugin-esbuild": "^6.1.1",
    "semantic-release": "^23.0.6",
    "typescript": "^5.4.3",
    "vitest": "^1.4.0"
  }
}
